{
  "name": "carl",
  "version": "0.1.0",
  "description": "Code Automated Review with LLM — a GitHub Action that reviews pull requests using AI via OpenRouter",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.1",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.16.0",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.2"
  }
}
